{
  "pythonVersion": "3.11",
  "pythonPlatform": "All",
  "typeCheckingMode": "basic",
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "stubPath": ".",
  "executionEnvironments": [
    {
      "root": ".",
      "pythonVersion": "3.11",
      "extraPaths": [".", "python_scripts", "python_scripts/lib"]
    }
  ],
  "include": ["python_scripts/**/*.py", "*.py"],
  "exclude": ["**/node_modules", "**/__pycache__", ".git"]
}
